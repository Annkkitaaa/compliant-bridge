# ── Compliance API ────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# API key required in x-api-key header for all non-health endpoints.
# The CRE workflow retrieves this from Vault DON secrets (key: complianceApiKey).
# For local simulation: set COMPLIANCE_API_KEY_ALL in your shell to this value.
COMPLIANCE_API_KEY=your-api-key-here

# Port to listen on (default: 3001)
PORT=3001
