# ── Deployer ──────────────────────────────────────────────────────────
PRIVATE_KEY=YOUR_DEPLOYER_PRIVATE_KEY

# ── RPC URLs ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARB_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Block Explorer API Keys (for contract verification) ──────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_KEY

# ── CCIP Router Addresses ────────────────────────────────────────────
# Official Chainlink CCIP Router contracts per chain
# See: https://docs.chain.link/ccip/supported-networks
CCIP_ROUTER_SEPOLIA=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
CCIP_ROUTER_ARB_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165
CCIP_ROUTER_BASE_SEPOLIA=0xD3b06cEbF099CE7DA4AcCf578aaebFDBd6e88a93

# ── LINK Token Addresses ─────────────────────────────────────────────
# Set to address(0) or leave empty to pay CCIP fees in native ETH
LINK_TOKEN_SEPOLIA=0x779877A7B0D9E8603169DdbD7836e478b4624789
LINK_TOKEN_ARB_SEPOLIA=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E
LINK_TOKEN_BASE_SEPOLIA=0xE4aB69C077896252FAFBD49EFD26B5D171A32410

# ── CCIP Chain Selectors ─────────────────────────────────────────────
# These are Chainlink's unique chain identifiers (NOT chain IDs)
CCIP_SELECTOR_SEPOLIA=16015286601757825753
CCIP_SELECTOR_ARB_SEPOLIA=3478487238524512106
CCIP_SELECTOR_BASE_SEPOLIA=10344971235874465080

# ── Deployed Contract Addresses (fill after deployment) ──────────────

# Source chain (Sepolia)
SRC_GATEWAY_ADDRESS=
SRC_TOKEN_ADDRESS=
SRC_REGULATOR_VIEW_ADDRESS=
SENDER_ADDRESS=
SRC_INVALIDATOR_ADDRESS=

# Destination chain (Arb Sepolia or Base Sepolia)
DST_GATEWAY_ADDRESS=
DST_TOKEN_ADDRESS=
DST_REGULATOR_VIEW_ADDRESS=
RECEIVER_ADDRESS=
DST_INVALIDATOR_ADDRESS=

# ── Configuration ────────────────────────────────────────────────────
# Address authorized to send attestations cross-chain (defaults to deployer)
COMPLIANCE_BOT=

# For cross-chain test (defaults to deployer address)
TEST_SUBJECT=

# Destination chain selector for test (defaults to Arb Sepolia)
DEST_CHAIN_SELECTOR=3478487238524512106

# Amount of LINK to fund CCIP contracts (defaults to 5 LINK)
LINK_FUND_AMOUNT=5000000000000000000

# Amount of native ETH to fund CCIP contracts (defaults to 0.1 ETH)
NATIVE_FUND_AMOUNT=100000000000000000
